# PRISM-AI Integration Keys
GITLAB_PAT=your_gitlab_personal_access_token_here
GROQ_API_KEY=your_groq_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# PRISM-AI Core Infrastructure
webhook_secret=your_secure_webhook_hmac_secret
database_url=postgresql://prism:prism@localhost:5432/prism
repo_cache_dir=/tmp/prism/repos

# Frontend Authentication (NextAuth.js)
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# NextAuth OAuth Providers
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITLAB_CLIENT_ID=your-gitlab-app-id
GITLAB_CLIENT_SECRET=your-gitlab-secret
