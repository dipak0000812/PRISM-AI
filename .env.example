# ─────────────────────────────────────────────
# PRISM — Environment Variables
# ─────────────────────────────────────────────

# GitLab Personal Access Token (api + ai_features scope)
# Required: reads MR diffs, posts comments, assigns reviewers
GITLAB_PAT=glpat-xxxxxxxxxxxxxxxxxxxx

# Anthropic API Key for Claude summary generation
# Required: generates AI risk summaries via claude-sonnet-4-20250514
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxx

# Webhook secret token — must match the token configured in GitLab webhook settings
WEBHOOK_SECRET=prism-webhook-secret-2026

# PostgreSQL connection string
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://prism:prism@localhost:5432/prism

# Local directory to cache cloned repositories
# Each repo is shallow-cloned (depth=100) and fetched on subsequent events
REPO_CACHE_DIR=/tmp/prism/repos

# Maximum BFS traversal depth for blast radius computation (default: 5)
MAX_GRAPH_DEPTH=5

# Risk score threshold to auto-add 'high-risk' label on MRs (default: 80)
RISK_BLOCK_THRESHOLD=80
